# Playwright MCP URL (used for browser-based fallback)
MCP_URL=http://playwright-mcp:3000

# LLM model for browser agent (default: gpt-4.1-mini)
AGENT_MODEL=gpt-4.1-mini

# LLM API keys (at least one required for browser agent fallback)
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Agent settings
AGENT_MAX_LOGIN_STEPS=15
AGENT_MAX_EXTRACT_STEPS=10
